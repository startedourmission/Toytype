{
  "manifest_version": 3,
  "name": "Toytype",
  "version": "1.0.0",
  "description": "내장 규칙으로 웹페이지와 구글 독스 원고의 오탈자를 찾고, 구글 독스에서는 문서 위치 선택을 지원합니다.",
  "minimum_chrome_version": "114",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Toytype",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["https://docs.google.com/document/*"],
      "js": ["engine.js", "content/generic.js"],
      "css": ["content/highlight.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["engine.js", "content/docs.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/docs-panel.css", "content/docs-page-bridge.js"],
      "matches": ["https://docs.google.com/*"]
    }
  ]
}
